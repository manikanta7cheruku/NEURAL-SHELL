{
  "manifest_version": 3,
  "name": "Seven Tab Sync",
  "version": "1.0.1",
  "description": "Syncs Chrome tab data with Seven AI for workspace management. 100% local — no data leaves your machine.",
  "permissions": [
    "tabs",
    "activeTab",
    "identity",
    "identity.email",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:7777/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Seven Tab Sync — Active"
  }
}