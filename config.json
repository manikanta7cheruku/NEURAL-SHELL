{
    "identity": {
        "name": "Seven",
        "creator": "Team Seven",
        "wake_words": [
            "seven",
            "hey seven",
            "wake up"
        ],
        "stop_words": [
            "stop",
            "shut up",
            "pause"
        ]
    },
    "brain": {
        "model_name": "llama3",
        "temperature": 0.3,
        "max_history": 10,
        "streaming": true,
        "auto_model": true,
        "model_tiers": {
            "high": "llama3",
            "medium": "phi3:mini",
            "low": "qwen2:1.5b",
            "minimum": "tinyllama"
        }
    },
    "vision": {
        "model_name": "llava"
    },
    "voice_id": {
        "enabled": true,
        "similarity_threshold": 0.82,
        "default_speaker": "mani"
    },
    "gui": {
        "opacity": 0.8,
        "bg_color": "#000000",
        "text_color": "#00FF00",
        "font_size": 12
    },
