        "screenshot_folder": "./screenshots",
        "log_file": "./chat_log.txt",
        "voice_prints": "./seven_data/voice_prints"
    },
    "interrupt": {
        "enabled": true,
        "words": [
            "stop",
            "seven",
            "hey seven",
            "shut up",
            "hold on",
            "wait",
            "pause"
        ],
        "listen_during_speech": true,
        "interrupt_cooldown": 1.5
    },
    "web": {
        "enabled": true,
        "max_results": 3,
        "news_max_results": 3,
        "timeout": 10
    },
    "windows": {
        "enabled": true,
        "snap_gap": 0,
        "default_monitor": 0
    },
