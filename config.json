        "enabled": true,
        "check_interval": 15,
        "default_alarm_message": "Time to wake up.",
        "default_reminder_time": "09:00",
        "fire_through_pause": true
    },
    "knowledge": {
        "enabled": true,
        "sources_dir": "seven_data/knowledge",
        "chunk_size": 500,
        "top_k": 3,
        "auto_index": true
